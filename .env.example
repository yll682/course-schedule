# 复制为 .env 并填入真实值
# cp .env.example .env

# ── 必需配置 ─────────────────────────────────────────────────────────────────

# 本地存储密码加密密钥（必填，未设置则启动失败）
# 生成方式：python -c "import secrets; print(secrets.token_hex(16))"
STORAGE_AES_KEY=change-this-to-a-random-16-char-key

# ── 可选配置 ─────────────────────────────────────────────────────────────────

# Flask session 签名密钥（可选，不设置则自动生成并保存到 .secret_key）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=change-this-to-a-random-32-char-string

# 教务系统 API 加密密钥（可选，使用默认值即可）
# JW_API_KEY=qzkj1kjghd=876&*

# 管理员学号列表（逗号分隔）
# ADMIN_USERS=2405309121,other_admin

# 是否开启 Flask 调试模式（生产必须为 false）
FLASK_DEBUG=false

# 监听端口（默认 5000）
PORT=5000

# SQLite 数据库路径（默认 courses.db，Docker 中建议使用默认值）
# DB_FILE=courses.db
