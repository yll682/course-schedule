# 复制为 .env 并填入真实值
# cp .env.example .env

# Flask session 签名密钥，必须修改为随机字符串（生产环境必填）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-string

# 本地存储密码加密密钥（可选，未设置则使用默认值）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(24))"
# STORAGE_AES_KEY=your-32-byte-storage-encryption-key

# 是否开启 Flask 调试模式（生产必须为 false）
FLASK_DEBUG=false

# 监听端口（默认 5000）
PORT=5000

# SQLite 数据库路径（默认 courses.db）
# DB_FILE=courses.db
